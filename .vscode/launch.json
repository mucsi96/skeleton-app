{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Start mock AI server",
      "request": "launch",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/mock_anthropic_server",
      "runtimeArgs": [
        "start"
      ],
      "runtimeExecutable": "npm",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "type": "node"
    },
    {
      "type": "java",
      "name": "Start server",
      "request": "launch",
      "cwd": "${workspaceFolder}/server",
      "mainClass": "io.github.mucsi96.skeleton.SkeletonApplication",
      "args": "--spring.profiles.active=local"
    }
  ]
}
